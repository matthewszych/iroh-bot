# Discord Bot Credentials
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Optional: Set for faster command deployment to a single server during development
GUILD_ID=your_test_server_id_here

# PostgreSQL Connection
DATABASE_URL=postgres://user:password@localhost:5432/iroh_bot

# OpenAI (for AI-generated Iroh responses)
OPENAI_API_KEY=your_openai_api_key_here

# Feature Flags
ENABLE_AI=false

# Optional: Redirect all bot responses to a specific channel
BOT_CHANNEL_ID=

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
NODE_ENV=development
