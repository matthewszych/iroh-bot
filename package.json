{
  "name": "iroh-bot",
  "version": "1.0.0",
  "description": "Uncle Iroh Discord Bot - Avatar-themed wisdom and element leveling system",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "ts-node src/bot.ts",
    "deploy": "ts-node src/deploy-commands.ts",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts -x ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix && prettier --write src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "discord",
    "bot",
    "avatar",
    "iroh"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "knex": "^3.2.10",
    "openai": "^6.42.0",
    "opusscript": "^0.0.8",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
